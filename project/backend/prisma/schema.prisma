// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  password_hash      String?
  username           String    @unique
  display_name       String?
  avatar_url         String?
  balance            Decimal   @default(0)
  oauth_provider     String?
  oauth_id           String?
  two_factor_secret  String?
  two_factor_enabled Boolean   @default(false)
  language           String    @default("en")
  is_online          Boolean   @default(false)
  last_seen          DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  orders             Order[]
  holdings           Holding[]
  portfolioSnapshots PortfolioSnapshot[]

  @@map("users")
}

enum AssetType {
  STOCK
  CRYPTO
  FOREX
  COMMODITY
}

model Asset {
  id             String    @id @default(uuid()) @db.Uuid
  symbol         String    @unique
  name           String
  type           AssetType
  currentPrice   Decimal   @default(0) @map("current_price") @db.Decimal(15, 6)
  change24h      Decimal   @default(0) @map("change_24h") @db.Decimal(10, 4)
  volume24h      Decimal   @default(0) @map("volume_24h") @db.Decimal(20, 2)
  marketCap      Decimal   @default(0) @map("market_cap") @db.Decimal(20, 2)
  logoUrl        String?   @map("logo_url")
  coingeckoId    String?   @map("coingecko_id")
  finnhubSymbol  String?   @map("finnhub_symbol")
  isActive       Boolean   @default(true) @map("is_active")
  priceUpdatedAt DateTime? @map("price_updated_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations added when trading module is built:
  orders   Order[]
  holdings Holding[]
  // priceAlerts PriceAlert[]

  @@map("assets")
}

enum OrderType {
  BUY
  SELL
}

enum OrderExecutionType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
}

model Order {
  id String @id @default(uuid()) @db.Uuid

  userId  String @map("user_id") @db.Uuid
  assetId String @map("asset_id") @db.Uuid

  type      OrderType
  orderType OrderExecutionType @map("order_type")

  quantity Decimal @db.Decimal(15, 8)
  price    Decimal @db.Decimal(15, 6)
  total    Decimal @db.Decimal(15, 2)

  status OrderStatus @default(PENDING)

  filledAt  DateTime? @map("filled_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [assetId], references: [id])

  @@map("orders")
}

model Holding {
  id String @id @default(uuid()) @db.Uuid

  userId  String @map("user_id") @db.Uuid
  assetId String @map("asset_id") @db.Uuid

  quantity Decimal @db.Decimal(15, 8)

  avgBuyPrice Decimal @map("avg_buy_price") @db.Decimal(15, 6)

  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  asset Asset @relation(fields: [assetId], references: [id])

  @@unique([userId, assetId])
  @@map("holdings")
}

model PortfolioSnapshot {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid

  totalValue Decimal @map("total_value") @db.Decimal(15, 2)

  balance Decimal @db.Decimal(15, 2)

  holdingsValue Decimal @map("holdings_value") @db.Decimal(15, 2)

  snapshotDate DateTime @map("snapshot_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, snapshotDate])
  @@map("portfolio_snapshots")
}
